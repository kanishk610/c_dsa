function largest(arr) {
    let max = arr[0];

    // Traverse from second and compare
    // every element with current max
    for (let i = 1; i < arr.length; i++)
        if (arr[i] > max)
            max = arr[i];

    return max;
}

// Driver Code
const arr = [20, 10, 20, 4, 100];
console.log(largest(arr));
